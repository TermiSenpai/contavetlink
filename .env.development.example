# Configuración de DESARROLLO.
# Copia a `.env.development` (ignorado por git) y adapta a tu máquina.

FLASK_ENV=development
LOG_LEVEL=DEBUG

# Secret key placeholder — suficiente para dev, jamás para prod.
SECRET_KEY=dev-only-change-in-production

# Rutas: por defecto la app usa `./var/` como app_data_dir en desarrollo.
# Descomenta si quieres apuntar a rutas alternativas.
# GESDAI_APP_DATA_DIR=./var
# GESDAI_DB_PATH=./var/gesdai_exporter.db
# GESDAI_EXPORTS_DIR=./var/exports
