# Variables compartidas entre dev y prod.
# Copia a `.env` si quieres overrides locales comunes a ambos entornos.
# Para valores específicos de cada entorno usa `.env.development` o `.env.production`.
# NUNCA commitear `.env`, `.env.development`, ni `.env.production` — solo estos .example.

# Puerto del servidor local
FLASK_RUN_PORT=5000

# Nivel de log por defecto (se puede pisar por entorno)
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
