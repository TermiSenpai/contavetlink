# Configuración de PRODUCCIÓN.
# Copia a `.env.production` en la máquina de COLVET (ignorado por git).
#
# El .exe de PyInstaller detecta `sys.frozen` y entra automáticamente en modo
# producción, así que este fichero solo es necesario si quieres forzar prod
# ejecutando desde el código fuente o pisar defaults.

FLASK_ENV=production
LOG_LEVEL=INFO

# OBLIGATORIO: genera con
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Rutas: en producción el default es %APPDATA%\GesdaiExporter\.
# Descomenta solo si necesitas una ubicación alternativa (p. ej. carpeta compartida).
# GESDAI_APP_DATA_DIR=
# GESDAI_DB_PATH=
# GESDAI_EXPORTS_DIR=
